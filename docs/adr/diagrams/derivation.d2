# 파생 그래프 — 공리 → 결정 → 경계
# 정본은 docs/adr/ontology.md — 이 파일은 뷰(view)다.
# 실선 = 파생(문서에 근거 명시), 점선 = 예외 또는 문제 있는 연결.
# 렌더링: d2 derivation.d2 derivation.svg

vars: {
  d2-config: {
    layout-engine: elk
  }
}

direction: down

ax: "000 — 세 공리 (서로 연역되지 않음)" {
  a1: "공리 1\n소유 분리\n(의미=서비스, 물리=filegate)"
  a2: "공리 2\n바이트 직결이 기본\n(중계는 선언된 예외)"
  a3: "공리 3\n내부 의존 0"
}

b1: "경계: 유저 개념 없음\n권한 검사는 영원히 서비스 몫"
b2: "경계: 클라이언트 메타데이터 불투명"
b3: "결정·집행 분리\n(detach는 서비스, purge는 filegate)"

d001: "001 provider는 설정이다"
d001a: "provider = 접근 계약\n(계정 단위 분산 공짜)"
d001b: "file / location 분리\n(위치는 가변 포인터)"
d001c: "capability 선언식"
d001d: "배치는 인터페이스 뒤\n(전략 교체·리밸런싱 가능)"

d002: "002 모든 바이트 접근은 lease다"
d002a: "확정 = 검증 게이트\n(바이트를 못 보므로 사후 대조)"
d002b: "lease = 유일한 감사 단위\n(접근 추적·고아 탐지 공짜)"
d002c: "보안 = capability\n(검문은 발급 앞, 열쇠는 좁고 짧게)"
d002d: "중계 모드\n(filegate 자체 발급, 서버기록형 토큰)"
d002e: "중계는 filegate에 산다\n(서비스마다 폴백 배관 금지)"

d003: "003 안정 URL은 서비스의 것"
d003a: "filegate에 익명 표면 없음\n(중계 바이트 엔드포인트만 예외)"
d003b: "filegate URL은 소모품\n(저장·임베드·캐시 금지)"

d004: "004 intent는 어휘, 배치는 카탈로그"
d004a: "설정 3계층\nproviders / profiles / clients"
d004b: "회계 두 축\nquota(약속) + capacity(물리)"

mt: "⚠ 전제: 하나의 filegate를\n여러 서비스가 공유한다\n(공리에 미선언 — 리뷰 A2)" {
  style: {
    fill: "#fff3cd"
    stroke: "#cc8800"
    stroke-dash: 5
  }
}

ax.a1 -> b1
ax.a1 -> b2
ax.a1 -> b3

ax.a1 -> d001
d001 -> d001a
d001 -> d001b
d001 -> d001c
d001b -> d001d

ax.a2 -> d002
d002 -> d002a
d002 -> d002b
d002 -> d002c
ax.a2 -> d002d: 예외 절 {
  style.stroke-dash: 3
}
ax.a1 -> d002e
d002d -- d002e

ax.a1 -> d003
d002c -> d003
d003 -> d003a
d003 -> d003b

ax.a1 -> d004
mt -> d004: {
  style.stroke-dash: 3
}
ax.a3 -> d004: "라벨은 공리 3이지만\n실제 근거 아님" {
  style.stroke-dash: 3
}
d004 -> d004a
d004 -> d004b
