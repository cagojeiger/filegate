FILEGATE_BIND=127.0.0.1:8080
FILEGATE_DATABASE_URL=postgres://filegate:filegate@127.0.0.1:55432/filegate
FILEGATE_DB_MAX_CONNECTIONS=5
FILEGATE_LOG_FORMAT=pretty # pretty | json

# 키 정책 (LOOKUP 루트): 미설정 시 개발 기본값 + 부팅 경고. 프로덕션 필수, 32바이트 이상.
FILEGATE_LOOKUP_ROOT_KEY_ID=local-dev
FILEGATE_LOOKUP_ROOT_SECRET=filegate-local-dev-lookup-root-secret

# 단일 provider 임시 설정 — 3계층 설정(ADR 004)으로 재편 예정
FILEGATE_S3_ENDPOINT=http://127.0.0.1:9000
FILEGATE_S3_REGION=us-east-1
FILEGATE_S3_ACCESS_KEY=filegate
FILEGATE_S3_SECRET_KEY=filegate-secret
FILEGATE_S3_BUCKET=filegate-std
FILEGATE_S3_FORCE_PATH_STYLE=true
