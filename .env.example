# 환경 변수 = 서버(프로세스) 설정과 비밀. 로컬은 이 파일을 .env로 복사한다.
# 배포에서는 ESO/배포 env가 공급한다. YAML(configs/)에는 비밀이 없다.

# 서버 설정 (미설정 시 로컬 기본값)
#FILEGATE_BIND=127.0.0.1:8080
#FILEGATE_LOG_FORMAT=pretty        # pretty | json
#FILEGATE_DATABASE_URL=postgres://filegate:filegate@127.0.0.1:55432/filegate
#FILEGATE_DB_MAX_CONNECTIONS=5

# provider 자격증명 (규약: FILEGATE_PROVIDER_<ID>_*) — 로컬 MinIO 전용 값
FILEGATE_PROVIDER_MINIO_LOCAL_ACCESS_KEY=filegate
FILEGATE_PROVIDER_MINIO_LOCAL_SECRET_KEY=filegate-secret
