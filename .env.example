# 설정은 전부 env다 (로컬은 이 파일을 .env로 복사, 배포는 TF가 만든 k8s Secret).
# 등록부(storages·clients·bindings)는 DB에 살고 운영자 API로 관리한다 (spec 01).

# 서버 설정 (미설정 시 로컬 기본값)
#FILEGATE_BIND=127.0.0.1:8080
#FILEGATE_LOG_FORMAT=pretty        # pretty | json
#FILEGATE_DATABASE_URL=postgres://filegate:filegate@127.0.0.1:55432/filegate
#FILEGATE_DB_MAX_CONNECTIONS=5

# 비밀 (필수 — 없으면 부팅 실패). 아래 값은 로컬 개발 전용.
FILEGATE_ENC_ROOT_SECRET=filegate-local-dev-enc-root-secret-32b!
FILEGATE_OPERATOR_TOKENS=fgop_local-dev
#FILEGATE_ENC_KEY_ID=v1

# 마스터 키 회전 전환기에만 설정 (spec 01 런북 — 복호 전용, 쌍으로만)
#FILEGATE_ENC_ROOT_SECRET_PREV=
#FILEGATE_ENC_KEY_ID_PREV=

# reconciler tick 간격 (기본 60초) — 테스트에서만 줄인다.
# FILEGATE_RECONCILER_INTERVAL_SECS=60

# 중계 바이트 엔드포인트의 공개 베이스 URL — 중계 storage(fs/force_relay)를
# 등록하려면 필수. 로컬 개발은 서버 자신의 주소.
FILEGATE_PUBLIC_URL=http://127.0.0.1:8080

# multipart (spec 02) — 이 선언 크기를 넘으면 create가 part 서술자를 발급한다.
# part 크기는 create 시점 값이 업로드별로 동결된다 (벤더 규칙: 5MiB~5GiB).
#FILEGATE_MULTIPART_THRESHOLD_BYTES=268435456
#FILEGATE_PART_SIZE_BYTES=67108864

# 이동 집행 정책 (spec 04) — 운영자 트리거, reconciler 집행.
# DELETE_DELAY는 스왑 후 old 실물 삭제까지의 지연으로, presigned GET 수명
# (READ_LEASE_TTL=900초)과 같다 — 발급된 URL이 사는 동안 실물이 사라지지 않게
# 한다 (1 미만 거부).
#FILEGATE_MOVE_MAX_ATTEMPTS=5
#FILEGATE_MOVE_DELETE_DELAY_SECS=900
#FILEGATE_MOVE_RETRY_BACKOFF_SECS=60

# S3 호환 표면 (spec 03)은 컨트롤과 같은 리스너(FILEGATE_BIND)에서 항상 켜진다 —
# 루트 path-style /{bucket}/{key}로 받고, 겹치는 이름(api·blobs·healthz·readyz)은
# 버킷으로 예약된다. 별도 리스너 env는 없다.
