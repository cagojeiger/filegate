# 설정은 전부 env다 (로컬은 이 파일을 .env로 복사, 배포는 TF가 만든 k8s Secret).
# 등록부(providers·profiles·clients)는 DB에 살고 운영자 API로 관리한다 (spec 01).

# 서버 설정 (미설정 시 로컬 기본값)
#FILEGATE_BIND=127.0.0.1:8080
#FILEGATE_LOG_FORMAT=pretty        # pretty | json
#FILEGATE_DATABASE_URL=postgres://filegate:filegate@127.0.0.1:55432/filegate
#FILEGATE_DB_MAX_CONNECTIONS=5

# 비밀 (필수 — 없으면 부팅 실패). 아래 값은 로컬 개발 전용.
FILEGATE_ENC_ROOT_SECRET=filegate-local-dev-enc-root-secret-32b!
FILEGATE_OPERATOR_TOKENS=fgop_local-dev
#FILEGATE_ENC_KEY_ID=v1

# 마스터 키 회전 전환기에만 설정 (spec 01 런북 — 복호 전용, 쌍으로만)
#FILEGATE_ENC_ROOT_SECRET_PREV=
#FILEGATE_ENC_KEY_ID_PREV=
