# copy to .env and adjust; never commit .env
FILEGATE_CONFIG=config/filegate.yaml
FILEGATE_DATABASE_URL=postgres://filegate:filegate@localhost:55432/filegate

# provider: minio-local (docker-compose defaults)
FILEGATE_MINIO_ACCESS_KEY=minioadmin
FILEGATE_MINIO_SECRET_KEY=minioadmin

# client api keys
FILEGATE_CLIENT_NOTEGATE_KEY=dev-notegate-key
